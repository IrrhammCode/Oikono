{
  "name": "oikono",
  "version": "1.0.0",
  "description": "OIKONO - Autonomous On-Chain Game Master on Somnia",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network somnia_testnet",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:agent": "hardhat run scripts/deploy-universal-agent.js --network somnia_testnet",
    "verify": "hardhat run scripts/verify.js --network somnia_testnet",
    "dev": "python3 -m http.server 9090 --directory frontend"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^17.4.2"
  }
}
